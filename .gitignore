# Raw dataset (do not commit; license permits but kept out of VCS by policy)
data/raw/

# Local index / embedding artifacts (regenerable)
data/processed/*.log
data/processed/*.npy
data/processed/*.index
data/processed/*.faiss
data/processed/bm25.pkl
data/processed/runs/

# P2 built graph index — large binaries, regenerable via `just build-graph` from the
# committed resolution output (kept: manifest.json, chunk_ids.json, the current symlink).
data/graph/*/kuzu
data/graph/*/kuzu.wal
data/graph/*/faiss.index

# Env / secrets
.env
.env.*

# Model / HF caches
.cache/
**/.cache/
hf_cache/

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/
